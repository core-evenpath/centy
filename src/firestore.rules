rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // HELPER FUNCTIONS FOR MULTI-WORKSPACE ARCHITECTURE
    // ============================================================================

    function isSuperAdmin() {
      return request.auth != null &&
             (request.auth.token.role == 'Super Admin' || request.auth.token.email == 'core@suupe.com');
    }

    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.role == 'Admin' ||
              request.auth.token.role == 'Super Admin' ||
              request.auth.token.email == 'core@suupe.com');
    }

    function isPartnerAdmin() {
      return request.auth != null && request.auth.token.role == 'partner_admin';
    }

    function isEmployee() {
      return request.auth != null && request.auth.token.role == 'employee';
    }

    function isPartner() {
        return request.auth != null && (isPartnerAdmin() || isEmployee());
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ============================================================================
    // MULTI-WORKSPACE PERMISSION FUNCTIONS (MAINTAINED FOR COMPATIBILITY)
    // ============================================================================

    // Check if user belongs to a specific partner (supports multi-workspace)
    function belongsToPartner(partnerId) {
      return request.auth != null &&
             (
               // Support legacy single partnerId (backward compatibility)
               request.auth.token.partnerId == partnerId ||
               // Support multi-workspace partnerIds array
               (request.auth.token.partnerIds != null &&
                partnerId in request.auth.token.partnerIds)
             );
    }

    // Check if user can access ANY of the partners they belong to
    function belongsToAnyPartner() {
      return request.auth != null &&
             (
               request.auth.token.partnerId != null ||
               (request.auth.token.partnerIds != null &&
                request.auth.token.partnerIds.size() > 0)
             );
    }

    function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
    }

    function canAccessPartner(partnerId) {
      return isAdmin() || belongsToPartner(partnerId);
    }

    function canModifyPartner(partnerId) {
      return isAdmin() || (isPartnerAdmin() && belongsToPartner(partnerId));
    }

    // Check if user has admin role in a specific partner workspace
    function isPartnerAdminFor(partnerId) {
      return isPartnerAdmin() && belongsToPartner(partnerId);
    }

    function hasValidPartnerData() {
      return request.resource.data.keys().hasAll(['name', 'email', 'tenantId']) &&
             request.resource.data.name is string &&
             request.resource.data.email is string &&
             request.resource.data.tenantId is string;
    }

    // ============================================================================
    // CORE COLLECTIONS
    // ============================================================================

    match /partners/{partnerId} {
      // Allow all authenticated users to read partners
      allow read: if isAuthenticated();
      // Allow list/query operations for authenticated users
      allow list: if isAuthenticated();
      allow create: if isAdmin() && hasValidPartnerData();
      allow update: if canModifyPartner(partnerId);
      allow delete: if isSuperAdmin();

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - CAMPAIGNS
      // ============================================================================
      match /campaigns/{campaignId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - MESSAGE TEMPLATES
      // ============================================================================
      match /messageTemplates/{templateId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - CONTACT GROUPS
      // ============================================================================
      match /contactGroups/{groupId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - CONTACTS
      // ============================================================================
      match /contacts/{contactId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId &&
                         // Prevent modification of immutable core fields
                         !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['partnerId', 'id', 'createdAt']);
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - TRADING PICKS
      // ============================================================================
      match /tradingPicks/{pickId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - VAULT FILES
      // ============================================================================
      match /vaultFiles/{fileId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId &&
                         request.resource.data.uploadedBy is string;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - FILE SEARCH STORES
      // ============================================================================
      match /fileSearchStores/{storeId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - VAULT QUERIES
      // ============================================================================
      match /vaultQueries/{queryId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId &&
                         request.resource.data.userId is string;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNERHUB - HUB DOCUMENTS (AI Inbox / Core Memory)
      // ============================================================================
      match /hubDocuments/{documentId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId &&
                         request.resource.data.uploadedBy is string &&
                         request.resource.data.keys().hasAll(['partnerId', 'name', 'mimeType', 'size', 'status', 'uploadedBy', 'createdAt']);
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId &&
                         !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['partnerId', 'uploadedBy', 'createdAt', 'id']);
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNERHUB - HUB THREADS (AI Chat Threads)
      // ============================================================================
      match /hubThreads/{threadId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId &&
                         request.resource.data.createdBy is string &&
                         request.resource.data.keys().hasAll(['partnerId', 'title', 'contextType', 'createdBy', 'createdAt', 'isActive']);
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId &&
                         !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['partnerId', 'createdBy', 'createdAt', 'id']);
        allow delete: if isSignedIn() &&
                         (resource.data.createdBy == request.auth.uid || canModifyPartner(partnerId)) &&
                         resource.data.partnerId == partnerId;

        match /messages/{messageId} {
          allow read: if canAccessPartner(partnerId);
          allow list: if canAccessPartner(partnerId);
          allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                           request.resource.data.threadId == threadId &&
                           request.resource.data.keys().hasAll(['threadId', 'role', 'content', 'createdAt']);
          allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                           !request.resource.data.diff(resource.data).affectedKeys()
                             .hasAny(['threadId', 'role', 'content', 'createdAt', 'id']);
          allow delete: if isSignedIn() && canModifyPartner(partnerId);
        }
      }

      // ============================================================================
      // PARTNERHUB - HUB AGENTS (Custom AI Agents/Personas)
      // ============================================================================
      match /hubAgents/{agentId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId &&
                         request.resource.data.keys().hasAll(['partnerId', 'name', 'systemPrompt', 'personality', 'isActive', 'createdAt']) &&
                         request.resource.data.name is string &&
                         request.resource.data.systemPrompt is string;
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId &&
                         !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['partnerId', 'createdAt', 'id', 'type']);
        allow delete: if isSignedIn() && canModifyPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
      }

      // ============================================================================
      // PARTNERHUB - HUB SIMULATOR SESSIONS
      // ============================================================================
      match /hubSimulatorSessions/{sessionId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
        allow create: if isSignedIn() && canAccessPartner(partnerId) &&
                         request.resource.data.partnerId == partnerId &&
                         request.resource.data.keys().hasAll(['partnerId', 'agentId', 'createdAt']);
        allow update: if isSignedIn() && canAccessPartner(partnerId) &&
                         resource.data.partnerId == partnerId;
        allow delete: if isSignedIn() && canModifyPartner(partnerId);
      }

      // ============================================================================
      // PARTNER SUBCOLLECTIONS - AI BROADCAST IDEAS (cached AI-generated campaigns)
      // ============================================================================
      match /broadcastIdeas/{ideaId} {
        allow read: if canAccessPartner(partnerId);
        allow list: if canAccessPartner(partnerId);
      }
    }

    // ============================================================================
    // BROADCASTS COLLECTION
    // ============================================================================

    match /broadcasts/{broadcastId} {
      allow read: if isAuthenticated() && canAccessPartner(resource.data.partnerId);
      allow list: if isAuthenticated() && belongsToAnyPartner();
      allow create: if isAuthenticated() &&
                       (isAdmin() || (isPartnerAdmin() && belongsToPartner(request.resource.data.partnerId))) &&
                       request.resource.data.keys().hasAll(['partnerId', 'method', 'message']) &&
                       request.resource.data.partnerId is string;
      allow update: if isAuthenticated() && canModifyPartner(resource.data.partnerId);
      allow delete: if isAuthenticated() && canModifyPartner(resource.data.partnerId);
    }

    match /adminUsers/{adminId} {
      allow read, write: if isSuperAdmin();
    }

    match /userMappings/{email} {
      allow read: if request.auth == null && resource.data.email == email.lower();
      allow read: if request.auth != null &&
                     (request.auth.token.email.lower() == email.lower() || isAdmin());
      allow write: if false;
    }

    // ============================================================================
    // USER-SPECIFIC COLLECTIONS
    // ============================================================================

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /userWorkspaceContexts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /userWorkspaceContext/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    // ============================================================================
    // TEAM MEMBERS
    // ============================================================================

    match /teamMembers/{memberId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow list: if isAuthenticated() &&
                     (isAdmin() ||
                      (isPartner() && belongsToAnyPartner()));
      allow write: if canModifyPartner(resource.data.partnerId);
      allow create: if isPartner() &&
                       (belongsToPartner(request.resource.data.partnerId) || isAdmin());
    }

    // ============================================================================
    // TASKS COLLECTION
    // ============================================================================

    match /tasks/{taskId} {
      allow read: if canAccessPartner(resource.data.partnerId) ||
                     (resource.data.assignedTo == request.auth.uid && belongsToAnyPartner());
      allow list: if isAuthenticated() &&
                     (isAdmin() ||
                      (isPartner() && belongsToAnyPartner()));
      allow write: if canModifyPartner(resource.data.partnerId) ||
                      (resource.data.assignedTo == request.auth.uid &&
                       belongsToPartner(resource.data.partnerId));
      allow create: if isPartner() && belongsToPartner(request.resource.data.partnerId);
    }

    // ============================================================================
    // INVITATION CODES
    // ============================================================================

    match /invitationCodes/{invitationId} {
      allow create: if isAdmin() || (isPartnerAdmin() && belongsToPartner(request.resource.data.partnerId));
      allow read: if isAdmin() ||
                     (isPartnerAdmin() && belongsToPartner(resource.data.partnerId)) ||
                     (isAuthenticated() && request.auth.token.phoneNumber == resource.data.phoneNumber);
      allow list: if isPartnerAdmin() ||
                     (isAuthenticated() && request.query.where.phoneNumber == request.auth.token.phoneNumber);
      allow update: if isPartnerAdmin() && belongsToPartner(resource.data.partnerId) ||
                       (isAuthenticated() && resource.data.phoneNumber == request.auth.token.phoneNumber && request.resource.data.status == 'accepted' && request.resource.data.acceptedBy == request.auth.uid);
      allow delete: if false;
    }

    // ============================================================================
    // MULTI-WORKSPACE USER MANAGEMENT
    // ============================================================================

    match /userWorkspaceLinks/{linkId} {
        allow read: if isOwner(resource.data.userId) || isPartnerAdminFor(resource.data.partnerId) || isAdmin();
        allow write: if isPartnerAdminFor(request.resource.data.partnerId) ||
                        (isOwner(request.resource.data.userId) && request.resource.data.status == 'invited') ||
                        isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isPartner();
      allow write: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================================================
    // CHAT COLLECTIONS
    // ============================================================================

    match /conversations/{conversationId} {
      allow read: if canAccessPartner(resource.data.partnerId) &&
                     (request.auth.uid in resource.data.participants || isSuperAdmin());
      allow list: if isSignedIn() &&
                     (isSuperAdmin() ||
                      (belongsToAnyPartner() && request.query.limit <= 100));
      allow update: if canAccessPartner(resource.data.partnerId) &&
                       request.auth.uid in resource.data.participants &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['partnerId', 'type', 'createdAt']);
      allow create: if isSignedIn() &&
                       canAccessPartner(request.resource.data.partnerId) &&
                       request.auth.uid in request.resource.data.participants &&
                       request.resource.data.keys().hasAll(['partnerId', 'participants', 'type', 'title', 'createdAt']) &&
                       request.resource.data.partnerId is string &&
                       request.resource.data.participants is list &&
                       request.resource.data.type in ['direct', 'group'] &&
                       request.resource.data.title is string;
      allow delete: if canModifyPartner(resource.data.partnerId) ||
                       (resource.data.createdBy == request.auth.uid && canAccessPartner(resource.data.partnerId));
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() &&
                     (canAccessPartner(resource.data.partnerId) || isSuperAdmin());
      allow list: if isSignedIn() &&
                     (isSuperAdmin() ||
                      (belongsToAnyPartner() && request.query.limit <= 200));
      allow create: if isSignedIn() &&
                       canAccessPartner(request.resource.data.partnerId) &&
                       request.auth.uid == request.resource.data.senderId &&
                       request.resource.data.keys().hasAll(['conversationId', 'senderId', 'content', 'type', 'createdAt', 'partnerId']) &&
                       request.resource.data.conversationId is string &&
                       request.resource.data.senderId is string &&
                       request.resource.data.content is string &&
                       request.resource.data.type in ['text', 'file', 'image', 'system'] &&
                       request.resource.data.partnerId is string;
      allow update: if isSignedIn() &&
                       (request.auth.uid == resource.data.senderId || canModifyPartner(resource.data.partnerId)) &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['conversationId', 'senderId', 'createdAt', 'partnerId']);
      allow delete: if isSignedIn() &&
                       (request.auth.uid == resource.data.senderId || canModifyPartner(resource.data.partnerId));
    }

    // ============================================================================
    // SMS MESSAGING COLLECTIONS
    // ============================================================================

    match /smsConversations/{conversationId} {
      allow read: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) || isSuperAdmin();
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToAnyPartner());
      allow update: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) ||
                       (!request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['partnerId', 'platform', 'customerPhone', 'type', 'title', 'id', 'createdBy', 'createdAt']));
      allow create: if
        (isSignedIn() &&
         canAccessPartner(request.resource.data.partnerId) &&
         request.resource.data.partnerId is string &&
         request.resource.data.platform == 'sms' &&
         request.resource.data.customerPhone is string) ||
        (request.resource.data.platform == 'sms' &&
         request.resource.data.customerPhone is string &&
         request.resource.data.partnerId is string &&
         request.resource.data.type is string);
      allow delete: if isSignedIn() && canModifyPartner(resource.data.partnerId);
    }

    match /smsMessages/{messageId} {
      allow read: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) || isSuperAdmin();
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToAnyPartner());
      allow create: if
        (isSignedIn() &&
         canAccessPartner(request.resource.data.partnerId) &&
         request.resource.data.direction == 'outbound' &&
         request.resource.data.platform == 'sms') ||
        (request.resource.data.direction == 'inbound' &&
         request.resource.data.platform == 'sms' &&
         request.resource.data.conversationId is string &&
         request.resource.data.partnerId is string);
      allow update: if
        (isSignedIn() && canAccessPartner(resource.data.partnerId)) ||
        (request.resource.data.platform == 'sms' &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['conversationId', 'senderId', 'content', 'direction', 'platform', 'partnerId', 'createdAt', 'id', 'type']));
      allow delete: if isSignedIn() && canModifyPartner(resource.data.partnerId);
    }

    // ============================================================================
    // WHATSAPP MESSAGING COLLECTIONS
    // ============================================================================

    match /whatsappConversations/{conversationId} {
      allow read: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) || isSuperAdmin();
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToAnyPartner());
      allow update: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) ||
                       (!request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['partnerId', 'platform', 'customerPhone', 'type', 'title', 'id', 'createdBy', 'createdAt']));
      allow create: if
        (isSignedIn() &&
         canAccessPartner(request.resource.data.partnerId) &&
         request.resource.data.partnerId is string &&
         request.resource.data.platform == 'whatsapp' &&
         request.resource.data.customerPhone is string) ||
        (request.resource.data.platform == 'whatsapp' &&
         request.resource.data.customerPhone is string &&
         request.resource.data.partnerId is string &&
         request.resource.data.type is string);
      allow delete: if isSignedIn() && canModifyPartner(resource.data.partnerId);
    }

    match /whatsappMessages/{messageId} {
      allow read: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) || isSuperAdmin();
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToAnyPartner());
      allow create: if
        (isSignedIn() &&
         canAccessPartner(request.resource.data.partnerId) &&
         request.resource.data.direction == 'outbound' &&
         request.resource.data.platform == 'whatsapp') ||
        (request.resource.data.direction == 'inbound' &&
         request.resource.data.platform == 'whatsapp' &&
         request.resource.data.conversationId is string &&
         request.resource.data.partnerId is string);
      allow update: if
        (isSignedIn() && canAccessPartner(resource.data.partnerId)) ||
        (request.resource.data.platform == 'whatsapp' &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['conversationId', 'senderId', 'content', 'direction', 'platform', 'partnerId', 'createdAt', 'id', 'type']));
      allow delete: if isSignedIn() && canModifyPartner(resource.data.partnerId);
    }

    // ============================================================================
    // TELEGRAM MESSAGING COLLECTIONS
    // ============================================================================

    // Telegram Bot Mappings - maps bot IDs to partner IDs for webhook routing
    match /telegramBotMappings/{botId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && canModifyPartner(request.resource.data.partnerId));
    }

    // Telegram Conversations collection
    match /telegramConversations/{conversationId} {
      allow read: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) || isSuperAdmin();
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToAnyPartner());
      allow update: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) ||
                       (!request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['partnerId', 'platform', 'chatId', 'chatType', 'customerTelegramId', 'id', 'createdAt']));
      allow create: if
        (isSignedIn() &&
         canAccessPartner(request.resource.data.partnerId) &&
         request.resource.data.partnerId is string &&
         request.resource.data.platform == 'telegram') ||
        (request.resource.data.platform == 'telegram' &&
         request.resource.data.chatId is number &&
         request.resource.data.partnerId is string);
      allow delete: if isSignedIn() && canModifyPartner(resource.data.partnerId);
    }

    // Telegram Messages collection
    match /telegramMessages/{messageId} {
      allow read: if (isSignedIn() && canAccessPartner(resource.data.partnerId)) || isSuperAdmin();
      allow list: if isSignedIn() && (isSuperAdmin() || belongsToAnyPartner());
      allow create: if
        (isSignedIn() &&
         canAccessPartner(request.resource.data.partnerId) &&
         request.resource.data.direction == 'outbound' &&
         request.resource.data.platform == 'telegram') ||
        (request.resource.data.direction == 'inbound' &&
         request.resource.data.platform == 'telegram' &&
         request.resource.data.conversationId is string &&
         request.resource.data.partnerId is string);
      allow update: if
        (isSignedIn() && canAccessPartner(resource.data.partnerId)) ||
        (request.resource.data.platform == 'telegram' &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['conversationId', 'telegramMessageId', 'content', 'direction', 'platform', 'partnerId', 'createdAt', 'id', 'type']));
      allow delete: if isSignedIn() && canModifyPartner(resource.data.partnerId);
    }

    // ============================================================================
    // META WHATSAPP INTEGRATION COLLECTIONS
    // ============================================================================

    match /metaPhoneMappings/{phoneNumberId} {
      allow read: if true;
      allow write: if canModifyPartner(request.resource.data.partnerId);
    }

    match /metaWhatsAppConversations/{conversationId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow list: if belongsToAnyPartner();
      allow create: if belongsToPartner(request.resource.data.partnerId);
      allow update: if canAccessPartner(resource.data.partnerId);
      allow delete: if canModifyPartner(resource.data.partnerId);
    }

    match /metaWhatsAppMessages/{messageId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow list: if belongsToAnyPartner();
      allow create: if belongsToPartner(request.resource.data.partnerId);
      allow update: if canAccessPartner(resource.data.partnerId);
    }

    match /metaMessageTemplates/{templateId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow list: if belongsToAnyPartner();
      allow create: if belongsToPartner(request.resource.data.partnerId);
      allow update: if canModifyPartner(resource.data.partnerId);
    }

    match /webhookLogs/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ============================================================================
    // MESSAGE READ RECEIPTS
    // ============================================================================

    match /messageReadReceipts/{receiptId} {
      allow read: if isSignedIn() && canAccessPartner(resource.data.partnerId);
      allow list: if isSignedIn() && canAccessPartner(resource.data.partnerId);
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.userId &&
                       canAccessPartner(request.resource.data.partnerId);
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ============================================================================
    // TYPING INDICATORS
    // ============================================================================

    match /typingIndicators/{indicatorId} {
      allow read: if isSignedIn() && canAccessPartner(resource.data.partnerId);
      allow list: if isSignedIn() && canAccessPartner(resource.data.partnerId);
      allow write: if isSignedIn() &&
                      request.auth.uid == request.resource.data.userId &&
                      canAccessPartner(request.resource.data.partnerId);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ============================================================================
    // CONVERSATION PARTICIPANTS
    // ============================================================================

    match /conversationParticipants/{participantId} {
      allow read: if isSignedIn() &&
                     (request.auth.uid == resource.data.userId || canAccessPartner(resource.data.partnerId));
      allow list: if isSignedIn() && canAccessPartner(resource.data.partnerId);
      allow create, update, delete: if canModifyPartner(resource.data.partnerId) ||
                                       (request.auth.uid == resource.data.userId && resource.data.role != 'admin');
    }

    // ============================================================================
    // BUSINESS & AI DATA COLLECTIONS
    // ============================================================================

    match /businessProfiles/{profileId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow write: if canModifyPartner(resource.data.partnerId);
      allow create: if isPartnerAdmin() && belongsToPartner(request.resource.data.partnerId);
    }

    match /aiMemory/{memoryId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow write: if isAdmin() || (isPartnerAdmin() && belongsToPartner(resource.data.partnerId));
      allow create: if isAdmin() || (isPartnerAdmin() && belongsToAnyPartner());
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isOwner(resource.data.userId);
      allow create: if isAuthenticated();
    }

    // ============================================================================
    // SYSTEM & METADATA COLLECTIONS
    // ============================================================================

    match /industries/{industryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /systemSettings/{settingId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================================================
    // ANALYTICS & REPORTING COLLECTIONS
    // ============================================================================

    match /analytics/{analyticsId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow write: if isAdmin();
      allow create: if isAdmin() || isPartnerAdmin();
    }

    match /reports/{reportId} {
      allow read: if canAccessPartner(resource.data.partnerId);
      allow write: if canModifyPartner(resource.data.partnerId);
      allow create: if isPartner() && belongsToPartner(request.resource.data.partnerId);
    }

    // ============================================================================
    // TWILIO PHONE NUMBER MAPPINGS
    // ============================================================================

    match /twilioPhoneMappings/{phoneNumber} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================================
    // EARLY ACCESS WAITLIST
    // ============================================================================

    match /earlyAccessSignups/{signupId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'createdAt']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.matches('.*@.*\\..*') &&
                       request.resource.data.createdAt is timestamp;
      allow read: if isSuperAdmin() || isAdmin();
      allow list: if isSuperAdmin() || isAdmin();
      allow update: if isSuperAdmin() || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================================
    // SECURITY: EXPLICIT DENY FOR UNDEFINED COLLECTIONS
    // ============================================================================

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
