
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Partners: Only authenticated admins can read/write partner data.
    // Partners can only read their own data.
    match /partners/{partnerId} {
      allow read: if request.auth != null && 
                  (request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin' || request.auth.uid == partnerId);
      allow write: if request.auth != null && 
                   (request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin');
    }

    // Team Members:
    // Partner admins can manage members of their own team.
    // Employees can read their own data.
    match /teamMembers/{userId} {
        allow read: if request.auth != null &&
                    (request.auth.token.partnerId == resource.data.partnerId || request.auth.uid == userId);
        allow create, update, delete: if request.auth != null &&
                           (request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == resource.data.partnerId) ||
                           (request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin');
    }

    // Tasks:
    // Partner admins can manage all tasks in their workspace.
    // Employees can only manage tasks assigned to them.
    match /tasks/{taskId} {
        allow read: if request.auth != null &&
                    (request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == resource.data.partnerId) ||
                    (request.auth.uid == resource.data.assignee);
        allow create, update, delete: if request.auth != null &&
                        (request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == resource.data.partnerId) ||
                        (request.auth.uid == resource.data.assignee);
    }
    
    // User Mappings: Used for tenant lookups during login.
    // Should be readable by any authenticated user attempting to log in.
    // Writes should be restricted to server-side admin processes.
    match /userMappings/{identifier} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side admin should write
    }

    // User Workspace Links: Controls which user has access to which workspace.
    // Users can read their own links. Writes are server-side.
    match /userWorkspaceLinks/{linkId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // Only server-side admin should write
    }

    // User Workspace Context: Stores the user's active workspace.
    // Users can read and write their own context.
    match /userWorkspaceContexts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin Users collection
    match /adminUsers/{userId} {
      allow read: if request.auth != null && 
                     (request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin');
      allow write: if request.auth != null && request.auth.token.role == 'Super Admin';
    }

    match /whatsappConversations/{conversationId} {
      allow read: if request.auth != null && 
        request.auth.token.partnerId == resource.data.partnerId;
      allow write: if request.auth != null && 
        request.auth.token.partnerId == resource.data.partnerId;
    }

    match /whatsappMessages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
