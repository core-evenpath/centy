rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows Super Admins and Admins to manage admin user profiles.
     * @path /adminUsers/{userId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role
     * @deny (create, update, delete) - If request.auth.uid is not an Admin
     * @deny (get, list) - If request.auth.uid is not an Admin
     * @principle Enforces role-based access control for managing admin users.
     */
    match /adminUsers/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows Super Admins, Admins and Partner Admins to manage partner organizations.
     * @path /partners/{partnerId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing partner organizations.
     */
    match /partners/{partnerId} {
      allow get: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow list: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows Super Admins and Admins to manage user mappings.
     *              Partner Admins can create user mappings.
     * @path /userMappings/{identifier}
     * @allow (create) - If request.auth.uid has 'Super Admin', 'Admin' or 'partner_admin' role
     * @allow (get, list, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role
     * @deny (get, list, update, delete) - If request.auth.uid is not an Admin
     * @deny (create) - If request.auth.uid is not an Admin or Partner Admin
     * @principle Enforces role-based access control for managing user mappings.
     */
    match /userMappings/{identifier} {
        allow get: if isAdmin();
        allow list: if isAdmin();
        allow create: if isAdmin() || isPartnerAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    /**
     * @description Allows Super Admins, Admins and Partner Admins to manage team member profiles.
     * @path /teamMembers/{userId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing team member profiles.
     */
    match /teamMembers/{userId} {
        allow get: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTeamMember(userId) == request.auth.token.partnerId);
        allow list: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTeamMember(userId) == request.auth.token.partnerId);
        allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == request.auth.token.partnerId);
        allow update: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTeamMember(userId) == request.auth.token.partnerId);
        allow delete: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTeamMember(userId) == request.auth.token.partnerId);
    }

    /**
     * @description Allows Super Admins, Admins and Partner Admins to manage user workspace links.
     * @path /userWorkspaceLinks/{linkId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     */
    match /userWorkspaceLinks/{linkId} {
      allow get: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromWorkspaceLink(linkId) == request.auth.token.partnerId);
      allow list: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromWorkspaceLink(linkId) == request.auth.token.partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == request.auth.token.partnerId);
      allow update: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromWorkspaceLink(linkId) == request.auth.token.partnerId);
      allow delete: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromWorkspaceLink(linkId) == request.auth.token.partnerId);
    }

    /**
     * @description Allows Super Admins, Admins and Partner Admins to manage tasks.
     * @path /tasks/{taskId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     */
    match /tasks/{taskId} {
      allow get: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTask(taskId) == request.auth.token.partnerId);
      allow list: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTask(taskId) == request.auth.token.partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == request.auth.token.partnerId);
      allow update: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTask(taskId) == request.auth.token.partnerId);
      allow delete: if isAdmin() || (isPartnerAdmin() && getPartnerIdFromTask(taskId) == request.auth.token.partnerId);
    }

    /**
     * @description Allows Super Admins, Admins, and Partner Admins to manage campaigns for a specific partner.
     * @path /partners/{partnerId}/campaigns/{campaignId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing campaigns.
     */
    match /partners/{partnerId}/campaigns/{campaignId} {
      allow get: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow list: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == partnerId);
      allow update: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow delete: if isAdmin() || isPartnerAdminForPartner(partnerId);
    }

    /**
     * @description Allows Super Admins, Admins, and Partner Admins to manage message templates for a specific partner.
     * @path /partners/{partnerId}/messageTemplates/{templateId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing message templates.
     */
    match /partners/{partnerId}/messageTemplates/{templateId} {
      allow get: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow list: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == partnerId);
      allow update: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow delete: if isAdmin() || isPartnerAdminForPartner(partnerId);
    }

    /**
     * @description Allows Super Admins, Admins, and Partner Admins to manage contact groups for a specific partner.
     * @path /partners/{partnerId}/contactGroups/{groupId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing contact groups.
     */
    match /partners/{partnerId}/contactGroups/{groupId} {
      allow get: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow list: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == partnerId);
      allow update: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow delete: if isAdmin() || isPartnerAdminForPartner(partnerId);
    }

    /**
     * @description Allows Super Admins, Admins, and Partner Admins to manage contacts for a specific partner.
     * @path /partners/{partnerId}/contacts/{contactId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing contacts.
     */
    match /partners/{partnerId}/contacts/{contactId} {
      allow get: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow list: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == partnerId);
      allow update: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow delete: if isAdmin() || isPartnerAdminForPartner(partnerId);
    }

    /**
     * @description Allows Super Admins, Admins, and Partner Admins to manage trading picks for a specific partner.
     * @path /partners/{partnerId}/tradingPicks/{pickId}
     * @allow (create, update, delete) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @allow (get, list) - If request.auth.uid has 'Super Admin' or 'Admin' role, or if the user is a Partner Admin associated with the partner
     * @deny (create, update, delete) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @deny (get, list) - If request.auth.uid is not an Admin or a Partner Admin associated with the partner
     * @principle Enforces role-based access control for managing trading picks.
     */
    match /partners/{partnerId}/tradingPicks/{pickId} {
      allow get: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow list: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow create: if isAdmin() || (isPartnerAdmin() && request.resource.data.partnerId == partnerId);
      allow update: if isAdmin() || isPartnerAdminForPartner(partnerId);
      allow delete: if isAdmin() || isPartnerAdminForPartner(partnerId);
    }
  }

  // --- Helper functions ---

  /**
   * @description Checks if the user is signed in.
   * @return True if the user is signed in, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }

  /**
   * @description Checks if the user has the 'Super Admin' or 'Admin' role.
   * @return True if the user is an admin, false otherwise.
   */
  function isAdmin() {
    return isSignedIn() && (request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
  }

    /**
     * @description Checks if the user has the 'partner_admin' role.
     * @return True if the user is a partner admin, false otherwise.
     */
    function isPartnerAdmin() {
        return isSignedIn() && request.auth.token.role == 'partner_admin';
    }

  /**
   * @description Checks if the user has the 'partner_admin' role and is associated with the given partner ID.
   * @param partnerId The ID of the partner to check.
   * @return True if the user is a partner admin for the given partner, false otherwise.
   */
    function isPartnerAdminForPartner(partnerId) {
        return isSignedIn() && request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == partnerId;
    }

    /**
     * @description Retrieves the partner ID from the user's authentication token.
     * @return The partner ID associated with the user, or null if not available.
     */
    function getPartnerIdFromAuth() {
        return request.auth.token.partnerId;
    }

  /**
   * @description Checks if the user is a Partner Admin and associated with the team member's partner ID.
   * @param teamMemberId The ID of the team member.
   * @return True if the user is a Partner Admin for the given team member's partner, false otherwise.
   */
    function isPartnerAdminForTeamMember(teamMemberId) {
        return isPartnerAdmin() && request.auth.token.partnerId == getPartnerIdFromTeamMember(teamMemberId);
    }

    /**
     * @description Gets the partner ID associated with a team member document.
     * @param teamMemberId The ID of the team member document.
     * @return The partner ID of the team member.
     */
    function getPartnerIdFromTeamMember(teamMemberId) {
        return get(/databases/$(database)/documents/teamMembers/$(teamMemberId)).data.partnerId;
    }

    /**
     * @description Checks if the user is a Partner Admin and associated with the workspace link's partner ID.
     * @param workspaceLinkId The ID of the user workspace link.
     * @return True if the user is a Partner Admin for the given workspace link's partner, false otherwise.
     */
    function isPartnerAdminForWorkspaceLink(workspaceLinkId) {
        return isPartnerAdmin() && request.auth.token.partnerId == getPartnerIdFromWorkspaceLink(workspaceLinkId);
    }

    /**
     * @description Gets the partner ID associated with a user workspace link document.
     * @param workspaceLinkId The ID of the user workspace link document.
     * @return The partner ID of the user workspace link.
     */
    function getPartnerIdFromWorkspaceLink(workspaceLinkId) {
        return get(/databases/$(database)/documents/userWorkspaceLinks/$(workspaceLinkId)).data.partnerId;
    }

    /**
     * @description Checks if the user is a Partner Admin and associated with the task's partner ID.
     * @param taskId The ID of the task.
     * @return True if the user is a Partner Admin for the given task's partner, false otherwise.
     */
    function isPartnerAdminForTask(taskId) {
        return isPartnerAdmin() && request.auth.token.partnerId == getPartnerIdFromTask(taskId);
    }

    /**
     * @description Gets the partner ID associated with a task document.
     * @param taskId The ID of the task document.
     * @return The partner ID of the task.
     */
    function getPartnerIdFromTask(taskId) {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data.partnerId;
    }
}