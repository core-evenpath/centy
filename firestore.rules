/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model, primarily centered around partners and their associated data.
 *
 * Data Structure:
 * - Partners: Top-level collection containing partner organization data.
 * - Admin Users: Top-level collection for internal administrator profiles.
 * - User Mappings: Top-level collection for mapping user identifiers (email/phone) to tenant IDs.
 * - Team Members: Top-level collection containing team member profiles.
 * - User Workspace Links: Top-level collection defining the relationship between users and workspaces.
 * - Tasks: Top-level collection storing tasks assigned to team members.
 * - Subcollections under Partners: Campaigns, Message Templates, Contact Groups, Contacts, and Trading Picks.
 *
 * Key Security Decisions:
 * - Partners and their subcollections are generally restricted to partner admins or employees.
 * - Listing of any collection is restricted to authenticated users and where appropriate, further scoped to the user's partnerId
 * - Schema validation is relaxed during this prototyping phase to enable rapid iteration. Authorization is strictly enforced.
 *
 * Denormalization for Authorization:
 * - Partner subcollections rely on the `partnerId` field within each document to enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the document based on the provided user ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the owner of the document based on the document's partner ID.
     */
    function isPartnerOwner(partnerId) {
        return isSignedIn() && request.auth.uid == partnerId;
    }

    /**
     * @description Checks if the current user is an existing owner of the document (signed in, is owner, and resource exists).
     */
    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the user is a partner admin.
     */
    function isPartnerAdmin() {
        return isSignedIn() && (request.auth.token.role == 'partner_admin' || request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
    }


    /**
     * @description Enforces partner-level access control.
     * @path /partners/{partnerId}
     * @allow (get) Authenticated user can retrieve a partner.
     * @allow (create) Authenticated user can create a partner if they are a partner admin.
     * @allow (update) Authenticated user can update a partner if they are a partner admin or Super Admin.
     * @allow (delete) Authenticated user can delete a partner if they are a Super Admin.
     * @deny (get) Unauthenticated user cannot retrieve a partner.
     * @deny (create) Authenticated user cannot create a partner if they are not a partner admin.
     * @deny (update) Authenticated user cannot update a partner if they are not a partner admin.
     * @deny (delete) Authenticated user cannot delete a partner if they are not a Super Admin.
     * @principle Enforces role-based access control for partners.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isPartnerAdmin();
      allow update: if isPartnerAdmin() || request.auth.token.role == 'Super Admin';
      allow delete: if request.auth.token.role == 'Super Admin';
    }

    /**
     * @description Enforces admin user access control.
     * @path /adminUsers/{userId}
     * @allow (get) Authenticated user can retrieve an admin user.
     * @allow (create) Super Admin can create an admin user.
     * @allow (update) Admin can update an admin user.
     * @allow (delete) Super Admin can delete an admin user.
     * @deny (get) Unauthenticated user cannot retrieve an admin user.
     * @deny (create) Authenticated user cannot create an admin user if they are not a Super Admin.
     * @deny (update) Authenticated user cannot update an admin user if they are not an Admin.
     * @deny (delete) Authenticated user cannot delete an admin user if they are not a Super Admin.
     * @principle Enforces role-based access control for admin users.
     */
    match /adminUsers/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.auth.token.role == 'Super Admin';
      allow create: if request.auth.token.role == 'Super Admin';
      allow update: if request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin';
      allow delete: if request.auth.token.role == 'Super Admin';
    }

    /**
     * @description Enforces user mapping access control.
     * @path /userMappings/{identifier}
     * @allow (get) Authenticated user can retrieve a user mapping.
     * @allow (create) Partner Admin can create a user mapping.
     * @allow (update) Partner Admin can update a user mapping.
     * @allow (delete) Partner Admin can delete a user mapping.
     * @deny (get) Unauthenticated user cannot retrieve a user mapping.
     * @deny (create) Authenticated user cannot create a user mapping if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a user mapping if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a user mapping if they are not a Partner Admin.
     * @principle Enforces role-based access control for user mappings.
     */
    match /userMappings/{identifier} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && isPartnerAdmin();
        allow create: if isPartnerAdmin();
        allow update: if isPartnerAdmin();
        allow delete: if isPartnerAdmin();
    }

    /**
     * @description Enforces team member access control.
     * @path /teamMembers/{userId}
     * @allow (get) Authenticated user can retrieve a team member.
     * @allow (create) Partner Admin can create a team member.
     * @allow (update) Partner Admin can update a team member.
     * @allow (delete) Partner Admin can delete a team member.
     * @deny (get) Unauthenticated user cannot retrieve a team member.
     * @deny (create) Authenticated user cannot create a team member if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a team member if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a team member if they are not a Partner Admin.
     * @principle Enforces role-based access control for team members.
     */
    match /teamMembers/{userId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && isPartnerAdmin();
        allow create: if isPartnerAdmin();
        allow update: if isPartnerAdmin();
        allow delete: if isPartnerAdmin();
    }

    /**
     * @description Enforces user workspace link access control.
     * @path /userWorkspaceLinks/{linkId}
     * @allow (get) Authenticated user can retrieve a user workspace link.
     * @allow (create) Partner Admin can create a user workspace link.
     * @allow (update) Partner Admin can update a user workspace link.
     * @allow (delete) Partner Admin can delete a user workspace link.
     * @deny (get) Unauthenticated user cannot retrieve a user workspace link.
     * @deny (create) Authenticated user cannot create a user workspace link if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a user workspace link if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a user workspace link if they are not a Partner Admin.
     * @principle Enforces role-based access control for user workspace links.
     */
    match /userWorkspaceLinks/{linkId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && isPartnerAdmin();
        allow create: if isPartnerAdmin();
        allow update: if isPartnerAdmin();
        allow delete: if isPartnerAdmin();
    }

    /**
     * @description Enforces task access control.
     * @path /tasks/{taskId}
     * @allow (get) Authenticated user can retrieve a task.
     * @allow (create) Partner Admin can create a task.
     * @allow (update) Partner Admin can update a task.
     * @allow (delete) Partner Admin can delete a task.
     * @deny (get) Unauthenticated user cannot retrieve a task.
     * @deny (create) Authenticated user cannot create a task if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a task if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a task if they are not a Partner Admin.
     * @principle Enforces role-based access control for tasks.
     */
    match /tasks/{taskId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && isPartnerAdmin();
        allow create: if isPartnerAdmin();
        allow update: if isPartnerAdmin();
        allow delete: if isPartnerAdmin();
    }

    /**
     * @description Enforces campaign access control within a partner.
     * @path /partners/{partnerId}/campaigns/{campaignId}
     * @allow (get) Authenticated user can retrieve a campaign within a partner.
     * @allow (create) Partner Admin can create a campaign within a partner.
     * @allow (update) Partner Admin can update a campaign within a partner.
     * @allow (delete) Partner Admin can delete a campaign within a partner.
     * @deny (get) Unauthenticated user cannot retrieve a campaign within a partner.
     * @deny (create) Authenticated user cannot create a campaign within a partner if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a campaign within a partner if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a campaign within a partner if they are not a Partner Admin.
     * @principle Enforces role-based access control for campaigns within a partner.
     */
    match /partners/{partnerId}/campaigns/{campaignId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && (request.auth.token.partnerId == partnerId || request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
        allow create: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow update: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow delete: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
    }

    /**
     * @description Enforces message template access control within a partner.
     * @path /partners/{partnerId}/messageTemplates/{templateId}
     * @allow (get) Authenticated user can retrieve a message template within a partner.
     * @allow (create) Partner Admin can create a message template within a partner.
     * @allow (update) Partner Admin can update a message template within a partner.
     * @allow (delete) Partner Admin can delete a message template within a partner.
     * @deny (get) Unauthenticated user cannot retrieve a message template within a partner.
     * @deny (create) Authenticated user cannot create a message template within a partner if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a message template within a partner if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a message template within a partner if they are not a Partner Admin.
     * @principle Enforces role-based access control for message templates within a partner.
     */
    match /partners/{partnerId}/messageTemplates/{templateId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && (request.auth.token.partnerId == partnerId || request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
        allow create: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow update: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow delete: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
    }

    /**
     * @description Enforces contact group access control within a partner.
     * @path /partners/{partnerId}/contactGroups/{groupId}
     * @allow (get) Authenticated user can retrieve a contact group within a partner.
     * @allow (create) Partner Admin can create a contact group within a partner.
     * @allow (update) Partner Admin can update a contact group within a partner.
     * @allow (delete) Partner Admin can delete a contact group within a partner.
     * @deny (get) Unauthenticated user cannot retrieve a contact group within a partner.
     * @deny (create) Authenticated user cannot create a contact group within a partner if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a contact group within a partner if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a contact group within a partner if they are not a Partner Admin.
     * @principle Enforces role-based access control for contact groups within a partner.
     */
    match /partners/{partnerId}/contactGroups/{groupId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && (request.auth.token.partnerId == partnerId || request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
        allow create: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow update: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow delete: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
    }

    /**
     * @description Enforces contact access control within a partner.
     * @path /partners/{partnerId}/contacts/{contactId}
     * @allow (get) Authenticated user can retrieve a contact within a partner.
     * @allow (create) Partner Admin can create a contact within a partner.
     * @allow (update) Partner Admin can update a contact within a partner.
     * @allow (delete) Partner Admin can delete a contact within a partner.
     * @deny (get) Unauthenticated user cannot retrieve a contact within a partner.
     * @deny (create) Authenticated user cannot create a contact within a partner if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a contact within a partner if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a contact within a partner if they are not a Partner Admin.
     * @principle Enforces role-based access control for contacts within a partner.
     */
    match /partners/{partnerId}/contacts/{contactId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && (request.auth.token.partnerId == partnerId || request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
        allow create: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow update: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow delete: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
    }

    /**
     * @description Enforces trading pick access control within a partner.
     * @path /partners/{partnerId}/tradingPicks/{pickId}
     * @allow (get) Authenticated user can retrieve a trading pick within a partner.
     * @allow (create) Partner Admin can create a trading pick within a partner.
     * @allow (update) Partner Admin can update a trading pick within a partner.
     * @allow (delete) Partner Admin can delete a trading pick within a partner.
     * @deny (get) Unauthenticated user cannot retrieve a trading pick within a partner.
     * @deny (create) Authenticated user cannot create a trading pick within a partner if they are not a Partner Admin.
     * @deny (update) Authenticated user cannot update a trading pick within a partner if they are not a Partner Admin.
     * @deny (delete) Authenticated user cannot delete a trading pick within a partner if they are not a Partner Admin.
     * @principle Enforces role-based access control for trading picks within a partner.
     */
    match /partners/{partnerId}/tradingPicks/{pickId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn() && (request.auth.token.partnerId == partnerId || request.auth.token.role == 'Super Admin' || request.auth.token.role == 'Admin');
        allow create: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow update: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
        allow delete: if isPartnerAdmin() && request.auth.token.partnerId == partnerId;
    }
  }
}