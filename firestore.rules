/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model, primarily centered around the 'partnerId' field.
 *
 * Data Structure:
 * - Partners: /partners/{partnerId} - Stores partner organization information.
 * - Admin Users: /adminUsers/{userId} - Stores internal admin user profiles.
 * - User Mappings: /userMappings/{identifier} - Maps user identifiers to tenant/partner IDs.
 * - Team Members: /teamMembers/{userId} - Stores partner team member profiles.
 * - User Workspace Links: /userWorkspaceLinks/{linkId} - Defines user-workspace relationships.
 * - Tasks: /tasks/{taskId} - Stores tasks assigned to team members.
 * - Campaigns: /partners/{partnerId}/campaigns/{campaignId} - Stores campaign data.
 * - Message Templates: /partners/{partnerId}/messageTemplates/{templateId} - Stores message templates.
 * - Contact Groups: /partners/{partnerId}/contactGroups/{groupId} - Stores contact groups.
 * - Contacts: /partners/{partnerId}/contacts/{contactId} - Stores contact information.
 * - Trading Picks: /partners/{partnerId}/tradingPicks/{pickId} - Stores trading picks.
 *
 * Key Security Decisions:
 * - Partners and subcollections enforce partner-level ownership via the 'partnerId' field.
 * - Admin users are not distinguished by role, so there are no special rules based on "Super Admin" vs. "Admin".
 * - 'list' operations are generally allowed for owners of user-scoped subcollections.
 * - Data validation is minimized in the prototyping phase to allow rapid iteration.
 *
 * Denormalization for Authorization:
 * - Partner-owned resources (campaigns, templates, contact groups, contacts, trading picks) must have the 'partnerId' field to ensure proper access control.
 *
 * Structural Segregation:
 * - No explicit structural segregation is being enforced, but the partner/subcollection structure inherently separates data between different partners.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's partnerId matches the resource's partnerId.
     */
    function isPartner(partnerId) {
      return isSignedIn() && request.auth.token.partnerId == partnerId;
    }

    /**
     * @description Checks if the authenticated user's partnerId matches the resource's partnerId.
     */
    function isExistingPartner(partnerId) {
      return isSignedIn() && request.auth.token.partnerId == partnerId && resource != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the resource's userId.
     */
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && resource != null;
    }

   /**
     * @description Stores information about each partner organization.
     * @path /partners/{partnerId}
     * @allow (create) User with matching UID can create a partner document.
     * @deny (create) User attempts to create a partner document with a mismatched UID.
     * @principle Enforces document ownership for writes.
     */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isPartner(partnerId);
      allow delete: if isPartner(partnerId);
    }

    /**
     * @description Stores internal admin user profiles.
     * @path /adminUsers/{userId}
     * @allow (create) Any authenticated user can create an admin user document.  This should be changed in production.
     * @deny (create) Unauthenticated user attempts to create an admin user document.
     * @principle Restricts access to a user's own data tree.
     */
    match /adminUsers/{userId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Maps user emails or phone numbers to their tenant ID for login.
     * @path /userMappings/{identifier}
     * @allow (create) Any authenticated user can create a user mapping document. This should be changed in production.
     * @deny (create) Unauthenticated user attempts to create a user mapping document.
     */
    match /userMappings/{identifier} {
        allow get: if true;
        allow list: if false;
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Stores profiles for all team members across all partners.
     * @path /teamMembers/{userId}
     *  @allow (create) Any authenticated user can create a team member document.  This should be changed in production.
     * @deny (create) Unauthenticated user attempts to create a team member document.
     * @principle Restricts access to a user's own data tree.
     */
    match /teamMembers/{userId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Defines the relationship between a user and a workspace.
     * @path /userWorkspaceLinks/{linkId}
     *  @allow (create) Any authenticated user can create a user workspace link document.  This should be changed in production.
     * @deny (create) Unauthenticated user attempts to create a user workspace link document.
     * @principle Restricts access to a user's own data tree.
     */
    match /userWorkspaceLinks/{linkId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

   /**
     * @description Stores tasks assigned to team members.
     * @path /tasks/{taskId}
     *  @allow (create) Any authenticated user can create a task document.  This should be changed in production.
     * @deny (create) Unauthenticated user attempts to create a task document.
     * @principle Restricts access to a user's own data tree.
     */
    match /tasks/{taskId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores messaging campaigns for a specific partner.
     * @path /partners/{partnerId}/campaigns/{campaignId}
     * @allow (create) Authenticated user with partnerId can create a campaign.
     * @deny (create) Authenticated user without partnerId cannot create a campaign.
     * @principle Enforces partner-level data isolation.
     */
    match /partners/{partnerId}/campaigns/{campaignId} {
      allow get: if true;
      allow list: if true;
      allow create: if isPartner(partnerId);
      allow update: if isPartner(partnerId);
      allow delete: if isPartner(partnerId);
    }

    /**
     * @description Stores message templates created by a partner.
     * @path /partners/{partnerId}/messageTemplates/{templateId}
     * @allow (create) Authenticated partner can create a message template.
     * @deny (create) Unauthenticated user or incorrect partnerId cannot create a message template.
     * @principle Enforces partner-level data isolation.
     */
    match /partners/{partnerId}/messageTemplates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if isPartner(partnerId);
      allow update: if isPartner(partnerId);
      allow delete: if isPartner(partnerId);
    }

    /**
     * @description Stores contact groups for a partner.
     * @path /partners/{partnerId}/contactGroups/{groupId}
     * @allow (list) Authenticated partner can list contact groups.
     * @allow (create) Authenticated partner can create a contact group.
     * @deny (create) Unauthenticated user cannot create a contact group.
     * @principle Enforces partner-level data isolation.
     */
    match /partners/{partnerId}/contactGroups/{groupId} {
      allow get: if true;
      allow list: if isPartner(partnerId);
      allow create: if isPartner(partnerId);
      allow update: if isPartner(partnerId);
      allow delete: if isPartner(partnerId);
    }

    /**
     * @description Stores individual contacts for a partner.
     * @path /partners/{partnerId}/contacts/{contactId}
     * @allow (create) Authenticated partner can create a contact.
     * @deny (create) Unauthenticated user cannot create a contact.
     * @principle Enforces partner-level data isolation.
     */
    match /partners/{partnerId}/contacts/{contactId} {
      allow get: if true;
      allow list: if true;
      allow create: if isPartner(partnerId);
      allow update: if isPartner(partnerId);
      allow delete: if isPartner(partnerId);
    }

    /**
     * @description Stores trading picks created by a partner.
     * @path /partners/{partnerId}/tradingPicks/{pickId}
     * @allow (create) Authenticated partner can create a trading pick.
     * @deny (create) Unauthenticated user cannot create a trading pick.
     * @principle Enforces partner-level data isolation.
     */
    match /partners/{partnerId}/tradingPicks/{pickId} {
      allow get: if true;
      allow list: if true;
      allow create: if isPartner(partnerId);
      allow update: if isPartner(partnerId);
      allow delete: if isPartner(partnerId);
    }
  }
}