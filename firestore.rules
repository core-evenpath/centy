rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to partner documents based on the partnerId.
     * @path /partners/{partnerId}
     * @allow (read) - Any authenticated user can read partner data.
     * @allow (create, update, delete) - Only the partner themselves can modify their data.
     * @deny (create, update, delete) - If the partnerId in the request does not match the document ID.
     * @principle Enforces resource ownership for write operations, requires authentication for all access.
     */
    match /partners/{partnerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == partnerId;
      allow update: if isSignedIn() && request.auth.uid == partnerId;
      allow delete: if isSignedIn() && request.auth.uid == partnerId;
    }

    /**
     * @description Restricts access to admin user documents. Admin listing is explicitly denied.
     * @path /adminUsers/{userId}
     * @allow (get) - Only authenticated users can retrieve individual admin user profiles.
     * @deny (list) - Admin user listing is not allowed.
     * @deny (create, update, delete) - No one can create, update, or delete admin user profiles through client-side rules.
     * @principle Restricts access to sensitive admin data to prevent unauthorized modification and enumeration.
     */
    match /adminUsers/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if false;
    }

    /**
     * @description Maps user emails or phone numbers to their tenant ID for login.
     * @path /userMappings/{identifier}
     * @allow (create) - Allow creating a mapping if the user is signed in. Ensure identifier is same as document.
     * @allow (get) - Allow getting a mapping if the user is signed in.
     * @allow (list) - Deny listing user mappings.
     * @deny (update, delete) - No one can update or delete user mappings.
     * @principle Enforces authentication for creating mappings and prevents unauthorized modification and enumeration.
     */
    match /userMappings/{identifier} {
        allow create: if isSignedIn() && request.auth.uid == identifier;
        allow get: if isSignedIn();
        allow list: if false;
        allow update, delete: if false;
    }

    /**
     * @description Stores profiles for all team members across all partners.
     * @path /teamMembers/{userId}
     * @allow (get, list) - Allow a partner to get and list all team members that have partnerId equal to request.
     * @allow (create) - Allow creating a new team member if the user is signed in, the userId matches, and partnerId matches.
     * @allow (update, delete) - Allow updating or deleting if userId exists, the user is signed in and both partnerId and userId match.
     * @principle Enforces authentication for all operations, and enforces partnerId/userId to ensure only owners modify data.
     */
    match /teamMembers/{userId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn() && request.auth.uid == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Defines the relationship between a user and a workspace.
     * @path /userWorkspaceLinks/{linkId}
     * @allow (get, list) - Allow getting and listing links if authenticated and partnerId matches.
     * @allow (create) - Allow creating a link if the user is signed in and the userId matches.
     * @allow (update, delete) - Allow updating or deleting if the user is signed in, partnerId matches, and the resource exists.
     * @principle Enforces authentication and matches partnerId/userId to ensure only authorized users can modify links.
     */
    match /userWorkspaceLinks/{linkId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid != null;
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
    }

    /**
     * @description Stores tasks assigned to team members.
     * @path /tasks/{taskId}
     * @allow (get, list) - Allow reading all the tasks from partnerId.
     * @allow (create) - Allow creating tasks if authenticated. Checks to make sure partnerId/tenantId exist.
     * @allow (update, delete) - Allow updating and deleting tasks if partnerId and tenantId match and the resource exists.
     */
    match /tasks/{taskId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
    }

    /**
     * @description Stores messaging campaigns for a specific partner.
     * @path /partners/{partnerId}/campaigns/{campaignId}
     * @allow (get, list) - Allow a partner to get and list campaigns if authenticated.
     * @allow (create) - Allow creating campaigns if partnerId matches the request.
     * @allow (update, delete) - Allow updating or deleting campaigns if the partnerId matches and resource exists.
     * @principle Enforces resource ownership and requires authentication for all access.
     */
    match /partners/{partnerId}/campaigns/{campaignId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == partnerId;
      allow update: if isSignedIn() && request.auth.uid == partnerId;
      allow delete: if isSignedIn() && request.auth.uid == partnerId;
    }

    /**
     * @description Stores message templates created by a partner.
     * @path /partners/{partnerId}/messageTemplates/{templateId}
     * @allow (get, list) - Allow a partner to get and list templates if authenticated.
     * @allow (create) - Allow creating templates if partnerId matches the request.
     * @allow (update, delete) - Allow updating or deleting templates if the partnerId matches and the resource exists.
     * @principle Enforces resource ownership and requires authentication for all access.
     */
    match /partners/{partnerId}/messageTemplates/{templateId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == partnerId;
      allow update: if isSignedIn() && request.auth.uid == partnerId;
      allow delete: if isSignedIn() && request.auth.uid == partnerId;
    }

    /**
     * @description Stores contact groups for a partner.
     * @path /partners/{partnerId}/contactGroups/{groupId}
     * @allow (get, list) - Allow a partner to get and list contact groups if authenticated.
     * @allow (create) - Allow creating contact groups if partnerId matches the request.
     * @allow (update, delete) - Allow updating or deleting contact groups if the partnerId matches and the resource exists.
     * @principle Enforces resource ownership and requires authentication for all access.
     */
    match /partners/{partnerId}/contactGroups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == partnerId;
      allow update: if isSignedIn() && request.auth.uid == partnerId;
      allow delete: if isSignedIn() && request.auth.uid == partnerId;
    }

    /**
     * @description Stores individual contacts for a partner.
     * @path /partners/{partnerId}/contacts/{contactId}
     * @allow (get, list) - Allow a partner to get and list contacts if authenticated.
     * @allow (create) - Allow creating contacts if partnerId matches the request.
     * @allow (update, delete) - Allow updating or deleting contacts if the partnerId matches and the resource exists.
     * @principle Enforces resource ownership and requires authentication for all access.
     */
    match /partners/{partnerId}/contacts/{contactId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == partnerId;
      allow update: if isSignedIn() && request.auth.uid == partnerId;
      allow delete: if isSignedIn() && request.auth.uid == partnerId;
    }

    /**
     * @description Stores trading picks created by a partner.
     * @path /partners/{partnerId}/tradingPicks/{pickId}
     * @allow (get, list) - Allow a partner to get and list trading picks if authenticated.
     * @allow (create) - Allow creating trading picks if partnerId matches the request.
     * @allow (update, delete) - Allow updating or deleting trading picks if the partnerId matches and the resource exists.
     * @principle Enforces resource ownership and requires authentication for all access.
     */
    match /partners/{partnerId}/tradingPicks/{pickId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == partnerId;
      allow update: if isSignedIn() && request.auth.uid == partnerId;
      allow delete: if isSignedIn() && request.auth.uid == partnerId;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }
}