rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'Super Admin';
    }

    function isAdmin() {
      return request.auth != null && (request.auth.token.role == 'Admin' || isSuperAdmin());
    }

    function isPartnerAdmin(partnerId) {
      return request.auth != null && request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == partnerId;
    }

    function isEmployee(partnerId) {
      return request.auth != null && request.auth.token.role == 'employee' && request.auth.token.partnerId == partnerId;
    }

    function belongsToPartner(partnerId) {
        return request.auth != null && request.auth.token.partnerIds.hasAny([partnerId]);
    }
    
    function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
    }

    // Matches any document in the 'partners' collection
    match /partners/{partnerId} {
      allow read: if isSuperAdmin() || isAdmin() || belongsToPartner(partnerId);
      allow write: if isSuperAdmin() || isAdmin() || isPartnerAdmin(partnerId);
    }
    
    match /adminUsers/{userId} {
        allow read, write: if isSuperAdmin();
    }
    
    match /userMappings/{identifier} {
        allow read, write: if true; // Publicly readable for login, writable by server-side flows
    }
    
    match /teamMembers/{userId} {
        allow read: if isSuperAdmin() || isAdmin() || belongsToPartner(resource.data.partnerId);
        allow write: if isSuperAdmin() || isAdmin() || isPartnerAdmin(resource.data.partnerId);
    }

    match /userWorkspaceLinks/{linkId} {
        // A user can read their own workspace links
        allow read: if isOwner(linkId.split('_')[0]) || isAdmin();
        // Only server-side flows can create/update links
        allow write: if false; 
    }
    
    match /tasks/{taskId} {
        allow read: if isSuperAdmin() || isAdmin() || belongsToPartner(resource.data.partnerId);
        allow write: if isSuperAdmin() || isAdmin() || isPartnerAdmin(resource.data.partnerId) || (isEmployee(resource.data.partnerId) && request.auth.uid == resource.data.assignee);
    }

    // Rules for Content Studio
    match /partners/{partnerId}/campaigns/{campaignId} {
        allow read, write, delete: if isPartnerAdmin(partnerId) || isEmployee(partnerId);
    }

    match /partners/{partnerId}/messageTemplates/{templateId} {
        allow read, write, delete: if isPartnerAdmin(partnerId) || isEmployee(partnerId);
    }

    match /partners/{partnerId}/contactGroups/{groupId} {
        allow read, write, delete: if isPartnerAdmin(partnerId) || isEmployee(partnerId);
    }
    
    match /partners/{partnerId}/contacts/{contactId} {
        allow read, write, delete: if isPartnerAdmin(partnerId) || isEmployee(partnerId);
    }
    
    match /partners/{partnerId}/tradingPicks/{pickId} {
        allow read, write, delete: if isPartnerAdmin(partnerId) || isEmployee(partnerId);
    }
  }
}
