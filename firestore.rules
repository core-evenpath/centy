
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // ============================================================================
    // PARTNER & ADMIN DATA
    // ============================================================================
    
    // Partners can be read by anyone (for public profiles), but only created/updated by admins.
    match /partners/{partnerId} {
      allow read;
      allow write: if request.auth != null && request.auth.token.role == 'Super Admin';
    }
    
    // Admin users can only be managed by Super Admins.
    match /adminUsers/{userId} {
        allow read, write: if request.auth != null && request.auth.token.role == 'Super Admin';
    }
    
    // User Mappings for tenant lookup. Read-only for clients.
    match /userMappings/{email} {
        allow read;
        allow create, update, delete: if false; // Server-side only
    }

    // ============================================================================
    // TEAM & WORKSPACE DATA
    // ============================================================================

    // Team members can be read by other members of the same partner org.
    // Only partner admins can create/update/delete members.
    match /teamMembers/{userId} {
      allow read: if request.auth != null && request.auth.token.partnerId == resource.data.partnerId;
      allow write: if request.auth != null && request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == resource.data.partnerId;
    }
    
    // User workspace links determine which workspaces a user can access.
    // They are managed server-side.
    match /userWorkspaceLinks/{linkId} {
        allow read: if request.auth != null && request.auth.uid == linkId.split('_')[0];
        allow write: if false; // Server-side only
    }
    
    // ============================================================================
    // CORE APPLICATION DATA (TASKS, WORKFLOWS, ETC.)
    // ============================================================================
    
    match /tasks/{taskId} {
      // Admins can read/write all tasks in their workspace
      // Employees can read/write tasks assigned to them
      allow read, write: if request.auth != null && (
        (request.auth.token.role == 'partner_admin' && request.auth.token.partnerId == resource.data.partnerId) ||
        (request.auth.token.role == 'employee' && request.auth.uid == resource.data.assignee)
      );
    }
    
    match /workflows/{workflowId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.token.role == 'partner_admin';
    }

    // ============================================================================
    // COMMUNICATION
    // ============================================================================

    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    match /messages/{messageId} {
      allow read, write: if request.auth != null; // Further rules can be added based on conversation participants
    }
    
    match /whatsappConversations/{conversationId} {
      allow read: if request.auth != null && 
        request.auth.token.partnerId == resource.data.partnerId;
      allow write: if request.auth != null && 
        request.auth.token.partnerId == resource.data.partnerId;
    }

    match /whatsappMessages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /smsConversations/{conversationId} {
      allow read: if request.auth != null && 
        request.auth.token.partnerId == resource.data.partnerId;
      allow write: if request.auth != null && 
        request.auth.token.partnerId == resource.data.partnerId;
    }

    match /smsMessages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ============================================================================
    // SYSTEM & AUDIT
    // ============================================================================
    
    match /auditLogs/{logId} {
        allow read: if request.auth != null && request.auth.token.role == 'Super Admin';
        allow write: if false; // Server-side only
    }
  }
}
