/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy This ruleset enforces a multi-tenant security model where partners have isolated data.
 *  Super Admins have read/write access to all data. Partner admins and employees have access only to data within their partner organization.
 *
 * @data_structure
 * - /partners/{partnerId}: Partner organization data.
 * - /adminUsers/{userId}: Internal admin user profiles.
 * - /userMappings/{identifier}: Maps user emails or phone numbers to their tenant ID.
 * - /teamMembers/{userId}: Team member profiles across all partners.
 * - /userWorkspaceLinks/{linkId}: Links users to partner workspaces.
 * - /tasks/{taskId}: Tasks assigned to team members.
 * - /partners/{partnerId}/campaigns/{campaignId}: Campaigns for a specific partner.
 * - /partners/{partnerId}/messageTemplates/{templateId}: Message templates created by a partner.
 * - /partners/{partnerId}/contactGroups/{groupId}: Contact groups for a partner.
 * - /partners/{partnerId}/contacts/{contactId}: Contacts for a partner.
 * - /partners/{partnerId}/tradingPicks/{pickId}: Trading picks created by a partner.
 *
 * @key_security_decisions
 * - Super Admins are trusted and have full access.
 * - Partner admins and employees are restricted to their respective partner's data.
 * - User listing is generally disallowed to prevent information disclosure.
 * - Data validation is relaxed in favor of rapid prototyping, focusing on authorization and relational integrity.
 * - The security posture defaults to strict: if a relationship or role is ambiguous, access is denied.
 *
 * @denormalization_for_authorization
 * - Partner-owned documents (Campaigns, MessageTemplates, ContactGroups, Contacts, TradingPicks) include a 'partnerId' field. This allows rules to quickly verify ownership without additional reads.
 * - TeamMember and UserWorkspaceLink documents include partnerId and userId which allows rules to verify a user's access to a partner's workspace.
 *
 * @structural_segregation N/A
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows Super Admins and the partner itself to read and write partner data.
     * @path /partners/{partnerId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces partner-level access control, allowing only authenticated users to manage partner data.
     */
    match /partners/{partnerId} {
      function isSuperAdmin() {
        return request.auth.token.role == 'Super Admin';
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins to manage admin user profiles.
     * @path /adminUsers/{userId}
     * @allow (get, list) request.auth.token.role == 'Super Admin'
     * @allow (create, update, delete) request.auth.token.role == 'Super Admin'
     * @deny (get, list) request.auth.token.role != 'Super Admin'
     * @deny (create, update, delete) request.auth.token.role != 'Super Admin'
     * @principle Restricts admin user management to Super Admins.
     */
    match /adminUsers/{userId} {
        function isSuperAdmin() {
          return request.auth.token.role == 'Super Admin';
        }

        function isSignedIn() {
          return request.auth != null;
        }

        allow get: if isSuperAdmin();
        allow list: if false;
        allow create: if isSuperAdmin();
        allow update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
    }

    /**
     * @description Allows authenticated users to read and write user mappings.
     * @path /userMappings/{identifier}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Requires authentication for access to user mapping data.
     */
    match /userMappings/{identifier} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
          return request.auth.token.role == 'Super Admin';
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees within a partner organization to manage team member profiles.
     * @path /teamMembers/{userId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces team member management based on role and partner affiliation.
     */
    match /teamMembers/{userId} {
        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        function isSignedIn() {
          return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees within a partner organization to manage user workspace links.
     * @path /userWorkspaceLinks/{linkId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces workspace link management based on role and partner affiliation.
     */
    match /userWorkspaceLinks/{linkId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees within a partner organization to manage tasks.
     * @path /tasks/{taskId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces task management based on role and partner affiliation.
     */
    match /tasks/{taskId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees to manage campaigns within their partner organization.
     * @path /partners/{partnerId}/campaigns/{campaignId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces campaign management within the partner context.
     */
    match /partners/{partnerId}/campaigns/{campaignId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        function getPartnerId() {
          return request.resource.data.partnerId == partnerId;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees to manage message templates within their partner organization.
     * @path /partners/{partnerId}/messageTemplates/{templateId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces message template management within the partner context.
     */
    match /partners/{partnerId}/messageTemplates/{templateId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        function getPartnerId() {
          return request.resource.data.partnerId == partnerId;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees to manage contact groups within their partner organization.
     * @path /partners/{partnerId}/contactGroups/{groupId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces contact group management within the partner context.
     */
    match /partners/{partnerId}/contactGroups/{groupId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        function getPartnerId() {
          return request.resource.data.partnerId == partnerId;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees to manage contacts within their partner organization.
     * @path /partners/{partnerId}/contacts/{contactId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces contact management within the partner context.
     */
    match /partners/{partnerId}/contacts/{contactId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        function getPartnerId() {
          return request.resource.data.partnerId == partnerId;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Allows Super Admins and partner admins/employees to manage trading picks within their partner organization.
     * @path /partners/{partnerId}/tradingPicks/{pickId}
     * @allow (get, list) request.auth != null
     * @allow (create, update, delete) request.auth != null
     * @deny (get, list) request.auth == null
     * @deny (create, update, delete) request.auth == null
     * @principle Enforces trading pick management within the partner context.
     */
    match /partners/{partnerId}/tradingPicks/{pickId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isSuperAdmin() {
            return request.auth.token.role == 'Super Admin';
        }

        function getPartnerId() {
          return request.resource.data.partnerId == partnerId;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }
  }
}