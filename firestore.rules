rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin users can read/write all data
    function isAdmin() {
      return request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin';
    }

    // Partner admins can manage resources within their own partner organization
    function isPartnerAdmin(partnerId) {
      return request.auth.token.partnerId == partnerId && request.auth.token.role == 'partner_admin';
    }
    
    // Employees can only manage resources assigned to them within their partner organization
    function isEmployee(partnerId) {
      return request.auth.token.partnerId == partnerId && request.auth.token.role == 'employee';
    }

    // The user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Partners collection
    match /partners/{partnerId} {
      allow read: if isAdmin() || isPartnerAdmin(partnerId) || isEmployee(partnerId);
      allow write: if isAdmin() || isPartnerAdmin(partnerId);
    }

    // userMappings collection
    match /userMappings/{email} {
      allow read, write: if true; // Publicly writable for signup, readable for login
    }

    // teamMembers collection
    match /teamMembers/{userId} {
      allow read: if isAdmin() || isPartnerAdmin(resource.data.partnerId);
      allow write: if isAdmin() || isPartnerAdmin(resource.data.partnerId);
    }

    // tasks collection
    match /tasks/{taskId} {
      allow read: if isAdmin() || isPartnerAdmin(resource.data.partnerId) || isOwner(resource.data.assignee);
      allow write: if isAdmin() || isPartnerAdmin(resource.data.partnerId) || isOwner(resource.data.assignee);
    }

    // whatsappConversations collection
    match /whatsappConversations/{conversationId} {
      allow read: if request.auth != null && 
        (isAdmin() || isPartnerAdmin(resource.data.partnerId));
      allow write: if request.auth != null && 
        (isAdmin() || isPartnerAdmin(resource.data.partnerId));
    }

    // whatsappMessages collection
    match /whatsappMessages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // smsConversations collection
    match /smsConversations/{conversationId} {
      allow read: if request.auth != null && 
        (isAdmin() || isPartnerAdmin(resource.data.partnerId));
      allow write: if request.auth != null && 
        (isAdmin() || isPartnerAdmin(resource.data.partnerId));
    }

    // smsMessages collection
    match /smsMessages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
