/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant data model with partner-based ownership.
 * Most data is scoped to a specific partner, with access generally restricted to
 * users associated with that partner.  Admin users can manage all partners.
 *
 * Data Structure:
 * - /partners/{partnerId}: Information about partner organizations.
 * - /adminUsers/{userId}: Information about internal admin users.
 * - /userMappings/{identifier}: Maps user identifiers (email/phone) to tenants.
 * - /teamMembers/{userId}: Profiles for team members across all partners.
 * - /userWorkspaceLinks/{linkId}: Links users to partner workspaces.
 * - /tasks/{taskId}: Tasks assigned to team members.
 * - /partners/{partnerId}/campaigns/{campaignId}: Campaigns for a partner.
 * - /partners/{partnerId}/messageTemplates/{templateId}: Message templates.
 * - /partners/{partnerId}/contactGroups/{groupId}: Contact groups.
 * - /partners/{partnerId}/contacts/{contactId}: Individual contacts.
 * - /partners/{partnerId}/tradingPicks/{pickId}: Trading picks created by a partner.
 *
 * Key Security Decisions:
 * - Admin users are not yet implemented in the ruleset, so all access is partner-scoped.
 * - List operations are generally allowed within a partner's scope.
 * - Data validation is minimal in this prototyping phase, focusing on relational integrity.
 *
 * Denormalization for Authorization:
 * - Partner-scoped data (campaigns, messageTemplates, etc.) requires a `partnerId` field
 *   on each document.  The rules enforce that this `partnerId` matches the path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows partners to manage their own profile information.
     * @path /partners/{partnerId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth.uid != null && request.resource.data.tenantId != null;
     * @allow (update, delete) if request.auth.uid != null && resource != null;
     * @deny create if request.resource.data.tenantId == null;
     * @deny update if request.resource.data.tenantId != resource.data.tenantId;
     * @principle Enforces partner-level access control.
     */
    match /partners/{partnerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Restricts access to admin user profiles.
     * @path /adminUsers/{userId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts access to admin user profiles.
     */
    match /adminUsers/{userId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of user mappings.
     * @path /userMappings/{identifier}
     * @allow get, list: if false;
     * @allow create: if isSignedIn();
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Enforces tenant-level access control.
     */
    match /userMappings/{identifier} {
      allow get, list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of team member profiles.
     * @path /teamMembers/{userId}
     * @allow get, list: if false;
     * @allow create: if isSignedIn();
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Enforces tenant-level access control.
     */
    match /teamMembers/{userId} {
      allow get, list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of user workspace links.
     * @path /userWorkspaceLinks/{linkId}
     * @allow get, list: if false;
     * @allow create: if isSignedIn();
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Enforces tenant-level access control.
     */
    match /userWorkspaceLinks/{linkId} {
      allow get, list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of tasks.
     * @path /tasks/{taskId}
     * @allow get, list: if false;
     * @allow create: if isSignedIn();
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Enforces tenant-level access control.
     */
    match /tasks/{taskId} {
      allow get, list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows partners to manage their campaigns.
     * @path /partners/{partnerId}/campaigns/{campaignId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
     * @allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @deny create if request.resource.data.partnerId != partnerId;
     * @deny update if request.resource.data.partnerId != partnerId;
     * @deny delete if resource.data.partnerId != partnerId;
     * @principle Enforces partner-level access control.
     */
    match /partners/{partnerId}/campaigns/{campaignId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
      allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
      allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
    }

    /**
     * @description Allows partners to manage their message templates.
     * @path /partners/{partnerId}/messageTemplates/{templateId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
     * @allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @deny create if request.resource.data.partnerId != partnerId;
     * @deny update if request.resource.data.partnerId != partnerId;
     * @deny delete if resource.data.partnerId != partnerId;
     * @principle Enforces partner-level access control.
     */
    match /partners/{partnerId}/messageTemplates/{templateId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
      allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
      allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
    }

    /**
     * @description Allows partners to manage their contact groups.
     * @path /partners/{partnerId}/contactGroups/{groupId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
     * @allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @deny create if request.resource.data.partnerId != partnerId;
     * @deny update if request.resource.data.partnerId != partnerId;
     * @deny delete if resource.data.partnerId != partnerId;
     * @principle Enforces partner-level access control.
     */
    match /partners/{partnerId}/contactGroups/{groupId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
      allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
      allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
    }

    /**
     * @description Allows partners to manage their contacts.
     * @path /partners/{partnerId}/contacts/{contactId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
     * @allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @deny create if request.resource.data.partnerId != partnerId;
     * @deny update if request.resource.data.partnerId != partnerId;
     * @deny delete if resource.data.partnerId != partnerId;
     * @principle Enforces partner-level access control.
     */
    match /partners/{partnerId}/contacts/{contactId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
      allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
      allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
    }

    /**
     * @description Allows partners to manage their trading picks.
     * @path /partners/{partnerId}/tradingPicks/{pickId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
     * @allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
     * @deny create if request.resource.data.partnerId != partnerId;
     * @deny update if request.resource.data.partnerId != partnerId;
     * @deny delete if resource.data.partnerId != partnerId;
     * @principle Enforces partner-level access control.
     */
    match /partners/{partnerId}/tradingPicks/{pickId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.partnerId == partnerId;
      allow update: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
      allow delete: if isSignedIn() && resource != null && resource.data.partnerId == partnerId;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}